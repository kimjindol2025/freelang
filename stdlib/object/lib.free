// stdlib/object - 객체 처리 라이브러리

FUNC keys(obj) {
  RETURN keys(obj)
}

FUNC values(obj) {
  RETURN values(obj)
}

FUNC entries(obj) {
  RETURN entries(obj)
}

FUNC merge(obj1, obj2) {
  RETURN merge(obj1, obj2)
}

FUNC clone(obj) {
  RETURN clone(obj)
}

FUNC hasKey(obj, key) {
  SET keys = keys(obj)
  RETURN array.includes(keys, key)
}

FUNC isEmpty(obj) {
  RETURN isEmpty(obj)
}
