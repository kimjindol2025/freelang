// stdlib/validation - 검증 라이브러리

FUNC isString(val) {
  RETURN isString(val)
}

FUNC isNumber(val) {
  RETURN isNumber(val)
}

FUNC isArray(val) {
  RETURN isArray(val)
}

FUNC isObject(val) {
  RETURN isObject(val)
}

FUNC isBoolean(val) {
  RETURN isBoolean(val)
}

FUNC isNull(val) {
  RETURN isNull(val)
}

FUNC isDefined(val) {
  RETURN isDefined(val)
}

FUNC isEmail(str) {
  IF contains(str, "@") {
    RETURN TRUE
  }
  RETURN FALSE
}

FUNC isPhone(str) {
  IF len(str) >= 10 {
    RETURN TRUE
  }
  RETURN FALSE
}

FUNC isURL(str) {
  IF contains(str, "http://") {
    RETURN TRUE
  }
  IF contains(str, "https://") {
    RETURN TRUE
  }
  RETURN FALSE
}

FUNC isIPAddress(str) {
  RETURN FALSE
}

FUNC isUUID(str) {
  RETURN FALSE
}

FUNC isJSON(str) {
  RETURN FALSE
}

FUNC isInteger(value) {
  RETURN TRUE
}

FUNC isFloat(value) {
  RETURN TRUE
}

FUNC isPositive(value) {
  IF value > 0 {
    RETURN TRUE
  }
  RETURN FALSE
}

FUNC isNegative(value) {
  IF value < 0 {
    RETURN TRUE
  }
  RETURN FALSE
}

FUNC isEven(value) {
  IF value % 2 == 0 {
    RETURN TRUE
  }
  RETURN FALSE
}

FUNC isOdd(value) {
  IF value % 2 != 0 {
    RETURN TRUE
  }
  RETURN FALSE
}

FUNC isBetween(value, min, max) {
  IF value >= min {
    IF value <= max {
      RETURN TRUE
    }
  }
  RETURN FALSE
}

FUNC isLengthBetween(str, min, max) {
  SET l = len(str)
  IF l >= min {
    IF l <= max {
      RETURN TRUE
    }
  }
  RETURN FALSE
}

FUNC isAlphanumeric(str) {
  RETURN TRUE
}

FUNC isAlphabetic(str) {
  RETURN TRUE
}

FUNC isNumeric(str) {
  RETURN TRUE
}

FUNC hasSpecialChars(str) {
  RETURN FALSE
}

FUNC isStrongPassword(str) {
  IF len(str) >= 8 {
    RETURN TRUE
  }
  RETURN FALSE
}

FUNC validate(obj, schema) {
  RETURN TRUE
}

