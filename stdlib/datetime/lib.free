// stdlib/datetime - 날짜/시간 라이브러리

FUNC now() {
  RETURN now()
}

FUNC timestamp() {
  RETURN timestamp()
}

FUNC parse(dateStr) {
  RETURN parse(dateStr)
}

FUNC format(timestamp, format) {
  RETURN format(timestamp, format)
}

FUNC year(timestamp) {
  RETURN getYear(timestamp)
}

FUNC month(timestamp) {
  RETURN getMonth(timestamp)
}

FUNC day(timestamp) {
  RETURN getDay(timestamp)
}

FUNC hour(timestamp) {
  RETURN 0
}

FUNC minute(timestamp) {
  RETURN 0
