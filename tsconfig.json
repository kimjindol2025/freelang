{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM", "WebWorker"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "noImplicitAny": false,
    "downlevelIteration": true
  },
  "include": ["src/mvp", "src/cli", "src/lexer", "src/parser", "src/codegen", "src/vm.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
