{
  "name": "freelang",
  "version": "2.1.0",
  "description": "Production-ready async runtime with self-healing, chaos engineering validation, and 30-day uptime guarantee",
  "main": "dist/cli/index.js",
  "types": "dist/cli/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "start": "node dist/cli/index.js",
    "dev": "ts-node src/cli/index.ts",
    "clean": "rm -rf dist coverage",
    "prepare": "npm run build"
  },
  "keywords": [
    "runtime",
    "async",
    "http-server",
    "javascript",
    "production",
    "self-healing",
    "chaos-engineering",
    "monitoring",
    "freelang"
  ],
  "author": "FreeLang Contributors <hello@freelang.dev>",
  "license": "MIT",
  "bin": {
    "freelang": "./bin/freelang"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/freelang/freelang.git"
  },
  "bugs": {
    "url": "https://github.com/freelang/freelang/issues"
  },
  "homepage": "https://github.com/freelang/freelang#readme",
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "ARCHITECTURE.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "examples"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "kpm": {
    "category": "language-runtime",
    "subcategory": "ai-compiler",
    "tags": [
      "ai",
      "code-generation",
      "c-backend",
      "freelang",
      "intent-parser",
      "self-correcting"
    ],
    "entry": "dist/cli/index.js",
    "cli": true,
    "version": "2.1.0",
    "dependencies": [],
    "exports": {
      "cli": "./dist/cli/index.js",
      "engine": "./dist/engine/auto-header.js",
      "parser": "./dist/parser/parser.js",
      "dashboard": "./dist/dashboard/dashboard.js"
    }
  }
}
